{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "tsx server/src/index.ts",
    "build:client": "npm --prefix client ci && npm --prefix client run build && rm -rf dist/public && mkdir -p dist/public && cp -r client/dist/. dist/public/",
    "build:server": "tsc -p tsconfig.server.json",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "build": "npm run build:client && npm run build:server && npm run build:scripts",
    "build:railway": "npm ci --include=dev && npm run build && npm prune --omit=dev",
    "start": "NODE_ENV=production node dist/server/src/index.js",
    "start:prod": "NODE_ENV=production node dist/server/src/index.js",
    "check": "tsc -p tsconfig.server.json --noEmit",
    "lint": "npm run check && npm --prefix client exec -- tsc -p tsconfig.json --noEmit",
    "db:push": "drizzle-kit push",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "restore": "tsx scripts/restoreBackup.ts",
    "migrate": "tsx scripts/runMigrations.ts",
    "migrate:prod": "node dist/scripts/runMigrations.js",
    "migrate:images": "node tools/fetch_and_store_images.js",
    "seed": "tsx scripts/runSeeds.ts",
    "seed:prod": "node dist/scripts/runSeeds.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dotenv-safe": "^9.1.0",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.18.1",
    "file-type": "^19.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "memorystore": "^1.6.7",
    "multer": "^1.4.5-lts.2",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "sharp": "^0.34.4",
    "typescript": "5.6.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv-safe": "^9.1.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.20.4"
    }
  },
  "//railway": "devDependencies se podan en producción con: npm prune --omit=dev"
}
