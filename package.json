{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "tsx server/index.ts",
    "build:client": "npm --prefix client ci && npm --prefix client run build && rm -rf dist/public && mkdir -p dist/public && cp -r client/dist/. dist/public/",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "build:railway": "npm ci --include=dev && npm run build && npm prune --omit=dev",
    "start": "NODE_ENV=production node dist/server/index.js",
    "check": "tsc -p tsconfig.server.json --noEmit",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^5.0.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "memorystore": "^1.6.7",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "zod": "^3.24.2",
    "typescript": "5.6.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/helmet": "^0.0.48",
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.20.4"
    }
  },
  "//railway": "devDependencies se podan en producción con: npm prune --omit=dev"
}
