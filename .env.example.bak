# Server
NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:5173

# PostgreSQL (used by server/src/db.ts)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=laptop_store
DB_NAME_TEST=laptop_store_test
DB_MAX=10
DB_IDLE_TIMEOUT=30000

# Optional fallback URL (legacy compatibility)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/laptop_store

# Client
VITE_API_URL=http://localhost:8000/api
