HOST=0.0.0.0
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-production-domain.example
CORS_ORIGIN=https://your-production-domain.example
ALLOWED_ORIGINS=https://your-production-domain.example
TRUST_PROXY=1
JWT_SECRET=replace_with_a_long_random_jwt_secret
SESSION_SECRET=replace_with_a_long_random_session_secret
COOKIE_SECURE=auto
DB_HOST=db
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=replace_with_db_password
DB_NAME=laptop_store
DB_NAME_TEST=laptop_store
DATABASE_URL=postgresql://admin:replace_with_db_password@db:5432/laptop_store
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_USER=notifications@your-domain.example
SMTP_PASS=replace_with_smtp_password
EMAIL_FROM="Laptop Store <notifications@your-domain.example>"
ADMIN_EMAIL=admin@your-domain.example
ADMIN_EMAILS=admin@your-domain.example
VITE_API_URL=/api
