# Runtime
NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=1h

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=laptop_store
DB_NAME_TEST=laptop_store_test
DB_MAX=10
DB_IDLE_TIMEOUT=30000

# Optional fallback URL (legacy compatibility)
DATABASE_URL=postgres://admin:password123@localhost:5432/laptop_store

# SMTP notifications (example values)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp_user
SMTP_PASS=smtp_password
EMAIL_FROM="Laptop Store <no-reply@example.com>"
ADMIN_EMAIL=admin@example.com
ADMIN_EMAILS=admin@example.com,ops@example.com

# Telegram notifications (example values)
TELEGRAM_BOT_TOKEN=replace_me
ADMIN_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=replace_me
ADMIN_CHAT_ENV_FILE=.env

# Security limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30

# Client
VITE_API_URL=http://localhost:8000/api
